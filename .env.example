# Supabase Configuration (Required)
# URL of your Supabase project (e.g., https://xyz.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon key for public client access
VITE_SUPABASE_ANON_KEY=eyJxh...

# Stripe Configuration (Required for payments)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Tawk.to Widget (Optional - for live chat)
VITE_TAWK_PROPERTY_ID=...

# Custom API Base URL (Optional - if using separate backend)
VITE_API_BASE_URL=https://api.yourdomain.com

# Web push public key (Optional - admin phone notifications)
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=